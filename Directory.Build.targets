<Project>

  <!-- Exclude auto-generated files from the CodeQL build to eliminate false positives:
         - Reqnroll/SpecFlow *.feature.cs runner files (~550 missed-readonly-modifier etc.)
         - xUnit XunitAutoGeneratedEntryPoint.cs files (missed-ternary-operator etc.)
       Pass -p:CodeQLBuild=true to the build command to activate this exclusion.
       Hand-written code in *.Specs projects (step definitions, hooks, helpers) is unaffected.

       Must be a Target (not a static ItemGroup) because both Reqnroll and xUnit add
       their generated files to Compile inside targets that run at execution time
       (IncludeProcessedReqnrollItemsToBuildInputs and _XunitAttachSourceFiles).
       A static Compile Remove fires at project-load time and is therefore a no-op. -->
  <Target Name="ExcludeGeneratedFilesFromCodeQL"
          AfterTargets="IncludeProcessedReqnrollItemsToBuildInputs;_XunitAttachSourceFiles"
          Condition="'$(CodeQLBuild)' == 'true'">
    <ItemGroup>
      <Compile Remove="**/*.feature.cs" />
      <Compile Remove="$(BaseIntermediateOutputPath)**/XunitAutoGeneratedEntryPoint$(DefaultLanguageSourceExtension)" />
    </ItemGroup>
  </Target>

</Project>
